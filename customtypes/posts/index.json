{
  "id": "posts",
  "label": "Posts",
  "repeatable": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "feature_image": {
        "type": "Image",
        "config": {
          "label": "Feature Image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "featured": {
        "type": "Boolean",
        "config": {
          "label": "Featured",
          "default_value": true,
          "placeholder_true": "On",
          "placeholder_false": "Off"
        }
      },
      "author": {
        "type": "Link",
        "config": {
          "label": "Author",
          "select": "document",
          "customtypes": [
            "author"
          ],
          "repeat": false
        }
      },
      "category": {
        "type": "Link",
        "config": {
          "label": "Category",
          "select": "document",
          "customtypes": [
            "post_category"
          ],
          "repeat": false
        }
      },
      "publishing_date": {
        "type": "Date",
        "config": {
          "label": "Publishing Date",
          "placeholder": ""
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "useAsTitle": true,
          "placeholder": "Title"
        }
      },
      "excerpt": {
        "type": "StructuredText",
        "config": {
          "label": "Excerpt",
          "placeholder": "Excerpt",
          "multi": "paragraph,strong,em",
          "allowTargetBlank": true
        }
      },
      "content": {
        "type": "StructuredText",
        "config": {
          "label": "Content",
          "placeholder": "Post body content",
          "multi": "paragraph,preformatted,heading1,heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,image,embed,list-item,o-list-item,rtl",
          "allowTargetBlank": true
        }
      },
      "tags": {
        "type": "Group",
        "config": {
          "label": "Tags",
          "repeat": true,
          "fields": {
            "tag": {
              "type": "Link",
              "config": {
                "label": "Tag",
                "select": "document",
                "customtypes": [
                  "post_tags"
                ],
                "repeat": false
              }
            }
          }
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {}
        }
      }
    },
    "SEO & Meta Data": {
      "meta_title": {
        "type": "Text",
        "config": {
          "label": "Meta Title",
          "placeholder": ""
        }
      },
      "meta_description": {
        "type": "Text",
        "config": {
          "label": "Meta Description",
          "placeholder": ""
        }
      },
      "meta_image": {
        "type": "Image",
        "config": {
          "label": "Meta Image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "keywords": {
        "type": "Group",
        "config": {
          "label": "Keywords",
          "repeat": true,
          "fields": {
            "word": {
              "type": "Text",
              "config": {
                "label": "Word",
                "placeholder": ""
              }
            }
          }
        }
      }
    }
  },
  "status": true,
  "format": "page"
}