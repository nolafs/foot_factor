{
  "id": "guide",
  "label": "Guide",
  "repeatable": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "name": {
        "type": "Text",
        "config": {
          "label": "Name",
          "useAsTitle": true,
          "placeholder": ""
        }
      },
      "feature_image": {
        "type": "Image",
        "config": {
          "label": "Feature Image",
          "constraint": {},
          "thumbnails": [
            {
              "name": "master",
              "width": 1920,
              "height": 1020
            },
            {
              "name": "thumb",
              "width": 331,
              "height": 408
            }
          ]
        }
      },
      "featured": {
        "type": "Boolean",
        "config": {
          "label": "Featured",
          "default_value": false,
          "placeholder_true": "true",
          "placeholder_false": "false"
        }
      },
      "publishing_date": {
        "type": "Date",
        "config": {
          "label": "Publishing Date",
          "placeholder": ""
        }
      },
      "author": {
        "type": "Link",
        "config": {
          "label": "Author",
          "select": "document",
          "customtypes": [
            {
              "id": "author",
              "fields": [
                "name",
                "link",
                "description",
                "profile_image"
              ]
            }
          ],
          "repeat": false
        }
      },
      "category": {
        "type": "Link",
        "config": {
          "label": "Category",
          "select": "document",
          "customtypes": [
            {
              "id": "condition_category",
              "fields": [
                "name"
              ]
            }
          ],
          "repeat": false
        }
      },
      "description": {
        "type": "StructuredText",
        "config": {
          "label": "Description",
          "placeholder": "",
          "multi": "heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,image,embed,list-item,o-list-item,paragraph",
          "allowTargetBlank": true
        }
      },
      "file": {
        "type": "Link",
        "config": {
          "label": "File",
          "placeholder": "",
          "select": "media",
          "allowText": true
        }
      },
      "tags": {
        "type": "Group",
        "config": {
          "label": "Tags",
          "repeat": true,
          "fields": {
            "tag": {
              "type": "Link",
              "config": {
                "label": "Tag",
                "select": "document",
                "customtypes": [
                  {
                    "id": "post_tags",
                    "fields": [
                      "name"
                    ]
                  }
                ],
                "repeat": false
              }
            }
          }
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "list": {
              "type": "SharedSlice"
            },
            "vertical_steps_with_images": {
              "type": "SharedSlice"
            },
            "case_studies": {
              "type": "SharedSlice"
            },
            "testimonial": {
              "type": "SharedSlice"
            },
            "sole_deconstruct": {
              "type": "SharedSlice"
            },
            "reviews": {
              "type": "SharedSlice"
            },
            "faqs": {
              "type": "SharedSlice"
            },
            "media_section": {
              "type": "SharedSlice"
            },
            "section": {
              "type": "SharedSlice"
            },
            "icon_nav_list": {
              "type": "SharedSlice"
            },
            "call_to_action": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "type": "Text",
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        }
      },
      "meta_description": {
        "type": "Text",
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        }
      },
      "meta_image": {
        "type": "Image",
        "config": {
          "label": "Meta Image",
          "constraint": {
            "width": 2400,
            "height": 1260
          },
          "thumbnails": []
        }
      },
      "keywords": {
        "type": "Group",
        "config": {
          "label": "Keywords",
          "repeat": true,
          "fields": {
            "word": {
              "type": "Text",
              "config": {
                "label": "word",
                "placeholder": ""
              }
            }
          }
        }
      }
    }
  },
  "status": true,
  "format": "page"
}