      "category": {
        "type": "Link",
        "config": {
          "label": "Category",
          "select": "document",
          "customtypes": [
            {
              "id": "condition_category",
              "fields": [
                "name",
                "image"
              ]
            }
          ],
          "repeat": false
        }
      },
      "excerpt": {
        "type": "Text",
        "config": {
          "label": "Excerpt",
          "placeholder": ""
        }
      },
      "tags": {
        "type": "Group",
        "config": {
          "label": "Tags",
