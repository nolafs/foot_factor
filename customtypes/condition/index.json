        "config": {
          "label": "Feature Image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "featured": {
        "type": "Boolean",
        "config": {
          "label": "Featured",
          "default_value": false,
          "placeholder_true": "true",
          "placeholder_false": "false"
        }
      },
      "author": {
        "type": "Link",
        "config": {
          "label": "Author",
          "select": "document",
          "customtypes": [
            {
              "id": "author",
