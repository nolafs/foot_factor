{
  "format": "page",
  "id": "treatment",
  "label": "Treatment",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "heading": {
        "type": "Text",
        "config": {
          "label": "Heading",
          "placeholder": ""
        }
      },
      "lead": {
        "type": "Text",
        "config": {
          "label": "Lead",
          "placeholder": ""
        }
      },
      "description": {
        "type": "Text",
        "config": {
          "label": "Description",
          "placeholder": ""
        }
      },
      "service": {
        "type": "Link",
        "config": {
          "label": "Service",
          "select": "document",
          "repeat": false,
          "customtypes": [
            {
              "id": "services",
              "fields": [
                "heading",
                {
                  "id": "category",
                  "customtypes": [
                    {
                      "id": "post_category",
                      "fields": ["name"]
                    }
                  ]
                }
              ]
            }
          ]
        }
      },
      "category": {
        "type": "Link",
        "config": {
          "label": "Category",
          "select": "document",
          "repeat": false,
          "customtypes": [
            {
              "id": "post_category",
              "fields": ["name"]
            }
          ]
        }
      },
      "wave": {
        "type": "Select",
        "config": {
          "label": "Wave",
          "placeholder": "",
          "options": ["default", "1", "2", "3", "4", "5", "6", "7", "8"]
        }
      },
      "feature_image": {
        "type": "Image",
        "config": {
          "label": "Feature Image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "featured": {
        "type": "Boolean",
        "config": {
          "label": "Featured",
          "placeholder_false": "false",
          "placeholder_true": "true",
          "default_value": false
        }
      },
      "weight": {
        "type": "Number",
        "config": {
          "label": "Weight",
          "placeholder": ""
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "list": {
              "type": "SharedSlice"
            },
            "section": {
              "type": "SharedSlice"
            },
            "vertical_steps_with_images": {
              "type": "SharedSlice"
            },
            "media_section": {
              "type": "SharedSlice"
            },
            "sole_deconstruct": {
              "type": "SharedSlice"
            },
            "testimonial": {
              "type": "SharedSlice"
            },
            "timeline": {
              "type": "SharedSlice"
            },
            "testimonials": {
              "type": "SharedSlice"
            },
            "reviews": {
              "type": "SharedSlice"
            },
            "icon_nav_list": {
              "type": "SharedSlice"
            },
            "faqs": {
              "type": "SharedSlice"
            },
            "case_studies": {
              "type": "SharedSlice"
            },
            "call_to_action": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        },
        "type": "Text"
      },
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_image": {
        "config": {
          "constraint": {
            "height": 1260,
            "width": 2400
          },
          "label": "Meta Image",
          "thumbnails": []
        },
        "type": "Image"
      }
    },
    "Pricing": {
      "price": {
        "type": "Number",
        "config": {
          "label": "Price",
          "placeholder": ""
        }
      },
      "features": {
        "type": "StructuredText",
        "config": {
          "label": "Features",
          "placeholder": "",
          "allowTargetBlank": true,
          "multi": "list-item,paragraph,strong"
        }
      },
      "has_booking": {
        "type": "Boolean",
        "config": {
          "label": "Has Booking",
          "placeholder_false": "false",
          "placeholder_true": "true",
          "default_value": false
        }
      },
      "has_telephone": {
        "type": "Boolean",
        "config": {
          "label": "Has Telephone",
          "placeholder_false": "false",
          "placeholder_true": "true",
          "default_value": false
        }
      }
    }
  }
}
